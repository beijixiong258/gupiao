# 只启用一个 LLM Provider。修改后重新启动程序。

# DeepSeek
LANGCHAIN_PROVIDER=deepseek
LANGCHAIN_MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI API Key：API 费用与 ChatGPT Pro 订阅分开计算。
# LANGCHAIN_PROVIDER=openai
# LANGCHAIN_MODEL_NAME=gpt-5.6
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# ChatGPT Pro / Codex OAuth：先运行 gpyj openai-login。
# LANGCHAIN_PROVIDER=openai_codex
# LANGCHAIN_MODEL_NAME=gpt-5.3-codex
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex

LANGCHAIN_TEMPERATURE=0.0
# OpenAI 推理模型可设 none / minimal / low / medium / high / xhigh；具体取值以所选模型支持范围为准。
# LANGCHAIN_REASONING_EFFORT=medium
TIMEOUT_SECONDS=180
MAX_RETRIES=2

# A 股数据。auto 模式优先 Tushare，失败后使用 AKShare。
TUSHARE_TOKEN=your-tushare-token
